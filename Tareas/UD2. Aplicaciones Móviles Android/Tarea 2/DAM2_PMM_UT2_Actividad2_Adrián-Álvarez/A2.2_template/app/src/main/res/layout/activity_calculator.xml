<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/gray">

    <Switch
        android:id="@+id/switch1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="onSwitchChanged"
        android:text="Estilo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.111"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.062"
        android:textColor="@color/white"/>


    <TextView
        android:id="@+id/Error"
        android:layout_width="211dp"
        android:layout_height="34dp"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.259" />

    <TextView
        android:id="@+id/Resultado"
        android:layout_width="311dp"
        android:layout_height="35dp"
        android:background="@color/graylight"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="25dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.135" />

    <TableLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:stretchColumns="*"
        app:layout_constraintTop_toBottomOf="@+id/Error"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fila 1: 7, 8, 9, + -->
        <TableRow
            android:layout_width="651dp"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/Button7"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="7"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button8"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="8"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button9"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="9"
                android:textStyle="bold" />

            <Button
                android:id="@+id/ButtonDivision"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_orange"
                android:onClick="operatorClick"
                android:text="/"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </TableRow>

        <!-- Fila 2: 4, 5, 6, - -->
        <TableRow>
            <Button
                android:id="@+id/Button4"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="4"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button5"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="5"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button6"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="6"
                android:textStyle="bold" />

            <Button
                android:id="@+id/ButtonX"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_orange"
                android:onClick="operatorClick"
                android:text="X"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </TableRow>

        <!-- Fila 3: 1, 2, 3, × -->
        <TableRow>
            <Button
                android:id="@+id/Button1"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button2"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="2"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button3"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="3"
                android:textStyle="bold" />

            <Button
                android:id="@+id/ButtonResta"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_orange"
                android:onClick="operatorClick"
                android:text="-"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </TableRow>

        <!-- Fila 4: C, 0, =, ÷ -->
        <TableRow>
            <Button
                android:id="@+id/ButtonC"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_orange"
                android:onClick="clearClick"
                android:text="C"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Button0"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_yellow"
                android:onClick="operandClick"
                android:text="0"
                android:textStyle="bold" />

            <Button
                android:id="@+id/ButtonEquals"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_fucsia"
                android:onClick="operatorClick"
                android:text="="
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/ButtonSuma"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_margin="4dp"
                android:background="@drawable/circulos_orange"
                android:onClick="operatorClick"
                android:text="+"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </TableRow>
    </TableLayout>

</androidx.constraintlayout.widget.ConstraintLayout>